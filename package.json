{
  "name": "arctravern",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:clean-ports": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-dev-ports.ps1 -Ports 5000,5001",
    "dev": "pnpm dev:clean-ports && pnpm --parallel --filter @arctravern/client --filter @arctravern/server dev",
    "dev:sh": "bash ./scripts/dev.sh",
    "dev:server:sh": "bash ./scripts/dev-server.sh",
    "dev:client:sh": "bash ./scripts/dev-client.sh",
    "dev:bat": "cmd /c .\\scripts\\dev.bat",
    "dev:server:bat": "cmd /c .\\scripts\\dev-server.bat",
    "dev:client:bat": "cmd /c .\\scripts\\dev-client.bat",
    "dev:client": "pnpm --filter @arctravern/client dev",
    "dev:server": "pnpm --filter @arctravern/server dev",
    "sync": "bash ./scripts/sync-latest.sh",
    "sync:bat": "cmd /c .\\scripts\\sync-latest.bat",
    "check": "vp run check -r",
    "build": "vp run build -r",
    "build:client": "pnpm --filter @arctravern/client build",
    "build:server": "pnpm --filter @arctravern/server build",
    "test": "vp run test -r",
    "test:client": "pnpm --filter @arctravern/client test",
    "test:server": "pnpm --filter @arctravern/server test",
    "ready": "pnpm check && pnpm test && pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "msw",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "shadcn": "^3.8.5",
    "vite-plus": "0.1.14"
  }
}
