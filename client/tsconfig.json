{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noUncheckedSideEffectImports": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["components", "hooks", "lib", "locales", "src", "stores", "vite.config.ts"],
  "exclude": ["coverage", "dist", "node_modules"]
}
